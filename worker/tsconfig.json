{
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "target": "es2020",
    "module": "nodenext",
    "lib": ["es2020", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../_shared" }
  ]
}