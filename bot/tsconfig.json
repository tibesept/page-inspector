{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "allowSyntheticDefaultImports": true,
    "paths": {
      "#api/*": ["./src/api/*"],
      "#bot/*": ["./src/bot/*"],
      "#core/*": ["./src/core/*"],
      "#repositories/*": ["./src/repositories/*"],
      "#services/*": ["./src/services/*"],
      "#types/*": ["./src/types/*"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../_shared" }
  ]
}