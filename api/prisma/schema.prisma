// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // Берёт строку подключения из файла .env
}

// Модель пользователя
model User {
  userId  BigInt   @id @unique// ID из телеграма, не автоинкремент
  balance Decimal  @default(0) @db.Decimal(10, 2)

  jobs Job[] // Связь: один пользователь может иметь много задач
  payments Payment[]
}

model Payment {
  id               String   @id @default(uuid()) // Это наш uniqueId (payload)
  userId           BigInt
  user             User     @relation(fields: [userId], references: [userId])

  // Здесь тоже ставим Decimal, чтобы типы совпадали при начислении
  amountCredits    Decimal  @db.Decimal(10, 2) 
  amountStars      Int
  status           String   @default("WAITING") // "WAITING", "DONE", "FAILED"
  telegramChargeId String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Добавим индекс, чтобы база мгновенно находила историю платежей юзера
  @@index([userId]) 
  @@index([telegramChargeId])
}

// Модель задачи (Job)
model Job {
  jobId   Int    @id @default(autoincrement()) // Уникальный ID задачи в нашей системе
  status  String @default("pending") // Статус по умолчанию

  // Поля, которые приходят при создании
  url     String
  type    Int
  settings String @default("{}")

  // Результат выполнения джобы
  result  String @default("")
  ai_summary String?

  // Связь с пользователем
  userId BigInt
  user   User @relation(fields: [userId], references: [userId])
}